// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Trip {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  description String?
  coverImage  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  stories     Story[]
  expenses    TripExpense[]   // ← renamed to avoid conflict with Story expenses
}

model TripExpense {
  id     String @id @default(cuid())
  tripId String
  trip   Trip   @relation(fields: [tripId], references: [id], onDelete: Cascade)
  title  String
  amount Float

  @@index([tripId])
}

model Story {
  id            String   @id @default(cuid())
  title         String
  slug          String   @unique
  city          String
  state         String?
  country       String
  coverImage    String
  content       String   @db.Text
  questionAsked String
  songName      String
  songEmbedUrl  String
  latitude      Float
  longitude     Float
  totalCost     Float
  coordinates   String?
  closingReflection String?
  tripId        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  trip            Trip?            @relation(fields: [tripId], references: [id], onDelete: SetNull)
  expenses        Expense[]
  journeySteps    JourneyStep[]
  routeStops      RouteStop[]
  recommendations Recommendation[]
  cityFrames      CityFrame[]
  photoMemories   PhotoMemory[]
}

model Expense {
  id      String @id @default(cuid())
  title   String
  amount  Float
  storyId String
  story   Story  @relation(fields: [storyId], references: [id], onDelete: Cascade)
}

model JourneyStep {
  id          String  @id @default(cuid())
  storyId     String
  title       String
  description String  @db.Text
  time        String?
  imageUrl    String?
  order       Int     @default(0)
  story       Story   @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@index([storyId, order])
}

model RouteStop {
  id        String  @id @default(cuid())
  storyId   String
  name      String
  note      String?
  latitude  Float
  longitude Float
  imageUrl  String?
  order     Int     @default(0)
  story     Story   @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@index([storyId, order])
}

model Recommendation {
  id            String  @id @default(cuid())
  storyId       String
  name          String
  type          String
  description   String
  latitude      Float?
  longitude     Float?
  googleMapsUrl String?
  priceRange    String?
  story         Story   @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@index([storyId])
}

model CityFrame {
  id          String  @id @default(cuid())
  storyId     String
  title       String
  description String?
  imageUrl    String
  order       Int     @default(0)
  story       Story   @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@index([storyId, order])
}

model PhotoMemory {
  id       String  @id @default(cuid())
  storyId  String
  imageUrl String
  caption  String?
  order    Int     @default(0)
  story    Story   @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@index([storyId, order])
}